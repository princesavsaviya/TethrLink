<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">


    <!-- ══════════════════════════════════════════════════════════════
         SCREEN 1-4 — Jetpack Compose UI
         ══════════════════════════════════════════════════════════════ -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeUiContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ══════════════════════════════════════════════════════════════
         SCREEN 5 — Streaming (surface + overlay)
         ══════════════════════════════════════════════════════════════ -->
    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- FPS pill -->
    <LinearLayout
        android:id="@+id/fpsPill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="14dp"
        android:background="@drawable/bg_fps_pill"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:visibility="gone">
        <View
            android:id="@+id/qualityDot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/dot_green"/>
        <TextView
            android:id="@+id/overlayFps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="-- FPS"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Tap overlay -->
    <FrameLayout
        android:id="@+id/streamOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_margin="12dp"
            android:background="@drawable/bg_overlay_panel"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_green"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:id="@+id/overlayServerName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Server"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/overlayFpsLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- FPS"
                    android:textColor="@color/success"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_chip"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resolution"
                        android:textColor="@color/text_hint"
                        android:textSize="9sp"/>
                    <TextView
                        android:id="@+id/overlayResolution"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--×--"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_chip"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Codec"
                        android:textColor="@color/text_hint"
                        android:textSize="9sp"/>
                    <TextView
                        android:id="@+id/overlayCodec"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <Button
                    android:id="@+id/disconnectBtn"
                    android:layout_width="72dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_danger"
                    android:stateListAnimator="@null"
                    android:text="End"
                    android:textColor="@color/danger_text"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="36dp"
            android:text="Tap to dismiss"
            android:textColor="@color/text_hint"
            android:textSize="11sp"/>
    </FrameLayout>

</FrameLayout>
