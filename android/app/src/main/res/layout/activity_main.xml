<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- ══════════════════════════════════════════════════════════════
         SCREEN 2 — USB Connected, Tethering Off
         ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/screenNoTethering"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TetherLink"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"/>

        <!-- USB-C Connected status bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp">
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/dot_green"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="USB-C Connected"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tethering OFF"
                android:textColor="@color/warning_text"
                android:textSize="11sp"
                android:background="@drawable/bg_button_warning"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <!-- Icon area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center">
            <LinearLayout
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_card_warning"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠"
                    android:textColor="@color/warning_text"
                    android:textSize="38sp"/>
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="USB Tethering Disabled"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:text="TetherLink needs USB Tethering to establish a network connection with your Linux machine."
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:layout_marginBottom="24dp"/>

        <!-- Open Settings button -->
        <Button
            android:id="@+id/openTetheringBtn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_button_primary"
            android:stateListAnimator="@null"
            android:text="↗  Open USB Tethering Settings"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Settings → Network → Hotspot &amp; Tethering → USB Tethering"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Setup checklist -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SETUP CHECKLIST"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <View
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="@drawable/dot_green"
                    android:layout_marginEnd="12dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USB-C cable connected"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <View
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="@drawable/bg_radar_dot"
                    android:layout_marginEnd="12dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USB Tethering enabled"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:background="@drawable/bg_radar_dot"
                    android:layout_marginEnd="12dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TetherLink server running on Linux"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════
         SCREEN 3 — Scanning for Server
         ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/screenScanning"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Header with status pills -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TetherLink"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"/>

        <!-- Status pills row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp">
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/dot_green"
                android:layout_marginEnd="5dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USB-C"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginEnd="14dp"/>
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/dot_green"
                android:layout_marginEnd="5dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tethering"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginEnd="14dp"/>
            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/dot_yellow"
                android:layout_marginEnd="5dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scanning"
                android:textColor="@color/text_hint"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Radar area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center">
            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="center">
                <View
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:background="@drawable/bg_radar_ring"
                    android:layout_gravity="center"
                    android:alpha="0.3"/>
                <View
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:background="@drawable/bg_radar_ring"
                    android:layout_gravity="center"
                    android:alpha="0.5"/>
                <LinearLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_button_primary"
                    android:gravity="center">
                    <ProgressBar
                        android:id="@+id/scanProgressBar"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:indeterminate="true"
                        android:indeterminateTint="@color/text_primary"/>
                </LinearLayout>
            </FrameLayout>
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Scanning for Server."
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="Make sure the TetherLink server is running on your Linux machine."
            android:textColor="@color/text_hint"
            android:textSize="13sp"
            android:paddingHorizontal="32dp"
            android:layout_marginBottom="16dp"/>

        <!-- Log card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="@drawable/dot_green"
                    android:layout_marginEnd="7dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TETHERLINK LOG"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"/>
            </LinearLayout>

            <TextView
                android:id="@+id/scanLogText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="$ Initializing..."
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.4"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════
         SCREEN 4 — Server Found
         ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/screenServerFound"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TetherLink"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="12dp"/>

        <!-- Success banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card_brand"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">
            <LinearLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_icon_btn"
                android:gravity="center"
                android:layout_marginEnd="12dp">
                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:background="@drawable/dot_green"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TetherLink Server Found!"
                    android:textColor="@color/success"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Signal strength: Excellent"
                    android:textColor="@color/text_hint"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Server info card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SERVER INFO"
                android:textColor="@color/text_hint"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="10dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="8dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_monitor"
                    android:alpha="0.6"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hostname"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/serverHostnameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/border_default"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="8dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_settings"
                    android:alpha="0.6"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="IP Address"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/serverIpText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/border_default"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="8dp">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/ic_back"
                    android:alpha="0.6"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="System"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/serverSystemText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

        <!-- Start Extending button -->
        <Button
            android:id="@+id/connectButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button_primary"
            android:stateListAnimator="@null"
            android:text="Start Extending  →"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/serverSummaryText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:layout_marginBottom="24dp"/>
    </LinearLayout>

    <!-- ══════════════════════════════════════════════════════════════
         SCREEN 5 — Streaming (surface + overlay)
         ══════════════════════════════════════════════════════════════ -->
    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- FPS pill -->
    <LinearLayout
        android:id="@+id/fpsPill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="14dp"
        android:background="@drawable/bg_fps_pill"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:visibility="gone">
        <View
            android:id="@+id/qualityDot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:background="@drawable/dot_green"/>
        <TextView
            android:id="@+id/overlayFps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="-- FPS"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Tap overlay -->
    <FrameLayout
        android:id="@+id/streamOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_margin="12dp"
            android:background="@drawable/bg_overlay_panel"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/dot_green"
                    android:layout_marginEnd="8dp"/>
                <TextView
                    android:id="@+id/overlayServerName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Server"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/overlayFpsLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- FPS"
                    android:textColor="@color/success"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_chip"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Resolution"
                        android:textColor="@color/text_hint"
                        android:textSize="9sp"/>
                    <TextView
                        android:id="@+id/overlayResolution"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--×--"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_stat_chip"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Codec"
                        android:textColor="@color/text_hint"
                        android:textSize="9sp"/>
                    <TextView
                        android:id="@+id/overlayCodec"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <Button
                    android:id="@+id/disconnectBtn"
                    android:layout_width="72dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_button_danger"
                    android:stateListAnimator="@null"
                    android:text="End"
                    android:textColor="@color/danger_text"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="36dp"
            android:text="Tap to dismiss"
            android:textColor="@color/text_hint"
            android:textSize="11sp"/>
    </FrameLayout>

</FrameLayout>
